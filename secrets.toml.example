# =============================================================================
# Ars Secrets Configuration (Infisical)
#
# このファイルを secrets.toml にコピーして値を設定してください。
#   cp secrets.toml.example secrets.toml
#
# 配置場所（優先順位順）:
#   1. カレントディレクトリ ./secrets.toml
#   2. ~/.config/ars/secrets.toml
#
# ⚠️ secrets.toml には認証情報が含まれるため、絶対にコミットしないでください。
# =============================================================================

[infisical]
# Infisical API host
host = "https://app.infisical.com"

# Machine Identity — Universal Auth credentials
# Infisical Dashboard > Project Settings > Machine Identities で作成
client_id = ""
client_secret = ""

# Infisical project (workspace) ID
project_id = ""

# Environment slug (dev / staging / production)
environment = "dev"

# Secret paths (Infisical folder structure)
#
# プロジェクト共有シークレット（OAuth credentials, DB URLs 等）:
#   /shared/GITHUB_CLIENT_ID
#   /shared/GITHUB_CLIENT_SECRET
#   /shared/GITHUB_REDIRECT_URI
#   /shared/REDIS_URL
#   /shared/SURREALDB_DATA_DIR
shared_path = "/shared"

# 個人シークレットのプレフィックス:
#   /personal/{user_id}/MY_TOKEN
personal_path_prefix = "/personal"

# キャッシュTTL（秒）— シークレットをメモリにキャッシュする期間
cache_ttl_secs = 300
